# Fly.io deploy token (flyctl tokens create deploy)
FLY_API_TOKEN=

# Infisical — shared across all agents
INFISICAL_PROJECT_ID=

# Infisical — per-agent machine identity credentials (suffix = agent name, uppercased)
INFISICAL_CLIENT_ID_IFRIT=
INFISICAL_CLIENT_SECRET_IFRIT=

# Add per-agent pairs as agents are onboarded, e.g.:
# INFISICAL_CLIENT_ID_SHIVA=
# INFISICAL_CLIENT_SECRET_SHIVA=
